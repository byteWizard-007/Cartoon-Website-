")}),y.jsx(Ct,{children:e("landing.pdf_ocr.landing_hero.hero_benefit_3")})],icon:gi,from:"PDF",to:"PDF",availableFormats:".pdf, .png, .jpg, .bmp, .jpeg, .tiff, .gif, .djvu",aboutSection:{title:e("landing.pdf_ocr.howTo.h2"),items:[e("landing.pdf_ocr.howTo.first"),e("landing.pdf_ocr.howTo.second"),e("landing.pdf_ocr.howTo.third")]},aboutSectionNoDelayFreeFlow:{title:e("landing.pdf_ocr.howTo.h2"),items:[e("main_page.features.0"),e("landing.pdf_ocr.howTo.first"),e("landing.pdf_ocr.howTo.second"),e("landing.pdf_ocr.howTo.third")]},ctaTitle:e("landing.pdf_ocr.CTA.title"),buttonLabel:e("landing.pdf_ocr.CTA.buttonLabel"),meta:{title:e("landing.pdf_ocr.meta.title"),description:e("landing.pdf_ocr.meta.description")}}],Bge="/assets/cms1500MainBg-CBDDFbPY.png",zge="/assets/cms-1500-ByRzL63b.pdf",Uge="/assets/ds11-ksY6QOkn.pdf",Vge="/assets/ds11MainBg-BlcglFX2.png",Hge="/assets/ds82-CL2F9kce.pdf",qge="/assets/ds82MainBg-DtaF2Lfa.png",Fu="/assets/formIcon1-DK6ZgX9y.svg",Lu="/assets/formIcon2-DmKqpXPg.svg",ju="/assets/formIcon3-v4_rruHg.svg",Mu="/assets/howToForm-6AoKGKAK.svg",Wge="/assets/i9MainBg-CuCclMo2.png",Gge="/assets/i864MainBg-C__KFltt.png",Kge="/assets/i-9-BW_9GVGe.pdf",Yge="/assets/i-864-z09hIZhE.pdf",Xge="/assets/w4MainBg-ircRdSDF.png",Jge="/assets/w9-C1yzV4Kp.pdf",Zge="/assets/w9MainBg-DgVrvgzR.png",Qge="/assets/w-4-Cr7oqEhk.pdf",e0e=()=>[{serviceType:hn.EDITOR,funnel:En.FILL_PDF,pagesCount:6,path:Ze.FORM_W9,filePath:Jge,fileName:"w9.pdf",name:"W-9",nameKey:"landing.form_w9.name",title:"Fill Out Form W-9: Request for Taxpayer Identification Number",description:"Latest Printable Template Available",caption:`This website is not affiliated with IRS <br/> 
      Form last updated: ${pc().format("MM/YYYY")}.<br/>
      Please verify this is the current version before use`,from:"PDF",to:"PDF",mainBackground:Zge,aboutSection:{title:"Get your Form W-9 now!",items:[{label:"Open the form",description:"Access the pre-loaded form directly in our PDF editor. No need to upload anything!",icon:Fu,color:"#3758F9"},{label:"Fill in your details",description:"Carefully complete all required fields to ensure accuracy and validity.",icon:Lu,color:"#13C296"},{label:"Download as PDF",description:"Save your filled-out form in PDF format, ready for submission or other needs.",icon:ju,color:"#3758F9"}]},whatIsSection:{title:"What is form W-9?",text:"Form W-9, Request for Taxpayer Identification Number, is important for anyone who needs to provide their Taxpayer Identification Number (TIN) to another person or business. This form helps the requester report your earnings to the IRS accurately. It's commonly used by independent contractors, freelancers, and vendors. Filling it out correctly ensures you receive the right tax documentation, like a 1099 form, for your income. Keeping this information updated can help prevent tax issues in the future."},howToSection:{title:"How to fill out Form W-9?",background:"#3758F9",icon:Mu,items:["<strong>Open</strong> the W-9 form in the PDF editor.","<strong>Fill</strong> in your name, business name (if applicable), and address in the appropriate fields","<strong>Select</strong> your tax classification (individual, corporation, etc.) by checking the correct box.","<strong>Enter</strong> your Taxpayer Identification Number (SSN or EIN).","<strong>Review</strong> all information for accuracy.","If required, <strong>sign</strong> the form electronically.","<strong>Download</strong> the completed form for submission."]},whoIsSection:{title:"Who needs to fill out Form W-9?",items:["Anyone who is asked to provide their Taxpayer Identification Number must complete Form W-9. This includes freelancers, contractors, and vendors.","Individuals who are not U.S. citizens or residents do not need to fill out this form."]},faqSection:{title:"FAQ",items:[{title:"What is the difference between an electronic and a digital signature?",text:"An electronic signature is a digital representation of a person's intent to sign a document, like typing your name or using a simple image of your signature. A digital signature, on the other hand, uses encryption to verify the signer’s identity and ensure the document hasn't been altered. At TheBestPDF, we support only electronic signatures, allowing you to sign forms simply and effectively."},{title:"Can I save my progress while filling out a form on TheBestPDF?",text:"Yes, we can save our progress while filling out a form on TheBestPDF. After editing, the file is saved in our account, allowing us to return anytime and continue working on it. This way, we don’t have to worry about losing our information and can take our time to complete the form accurately."},{title:"Can I submit my completed forms with TheBestPDF?",text:"No, we cannot submit completed forms using TheBestPDF. Our platform allows you to fill out forms and download them for your records, but it does not support submitting or sharing them online. Once you've filled out your form, you can save it to your device for later use or to send by mail."},{title:"Can I access TheBestPDF on mobile devices or tablets?",text:"Yes, we can access TheBestPDF on mobile devices and tablets. Our platform is designed to work on various screens, allowing busy professionals to fill out official forms on the go. Just open your device's web browser, and you can start editing PDFs wherever you are. Enjoy the convenience of managing your forms anytime, anywhere!"}]},contentNav:["What is a W-9 form?","How to fill a W-9 form?","Who is required to fill out a W-9 form?","FAQ"],ctaTitles:["Complete form W-9 for taxes","Fill form W-9 for tax info needs"],meta:{title:"Easily Manage Your Documents with TheBestPDF",description:"Welcome to our cutting-edge SaaS platform for online document editing and conversion. Designed to meet the needs of businesses and entrepreneurs."},icon:Nl,availableFormats:".pdf"},{serviceType:hn.EDITOR,funnel:En.FILL_PDF,pagesCount:6,path:Ze.FORM_DS11,filePath:Uge,fileName:"ds11.pdf",name:"DS-11",nameKey:"landing.form_ds11.name",title:"Fill Out Your DS-11 Passport Application Form Here",description:"Get the Latest Printable Template",caption:`This website is not affiliated with IRS <br/> 
      Form last updated: ${pc().format("MM/YYYY")}.<br/>
      Please verify this is the current version before use`,from:"PDF",to:"PDF",mainBackground:Vge,aboutSection:{title:"Get your Form DS-11 Application for a U.S. Passport now!",items:[{label:"Open the form",description:"Access the pre-loaded form directly in our PDF editor. No need to upload anything!",icon:Fu,color:"#3758F9"},{label:"Fill in your details",description:"Carefully complete all required fields to ensure accuracy and validity.",icon:Lu,color:"#13C296"},{label:"Download as PDF",description:"Save your filled-out form in PDF format, ready for submission or other needs.",icon:ju,color:"#3758F9"}]},whatIsSection:{title:"What is form DS-11?",text:"Form DS-11 is the Application for a U.S. Passport. It’s important because it allows U.S. citizens to apply for their first passport or replace a lost or stolen one. A passport is essential for international travel, as it proves your identity and citizenship. Completing this form accurately ensures you can receive your passport without delays. Remember, it must be submitted in person at an authorized acceptance facility or Passport Agency."},howToSection:{title:"How to fill out Form DS-11?",background:"#3758F9",icon:Mu,items:["<strong>Open</strong> the Form DS-11 in your PDF editor. ","<strong>Fill</strong> in your personal information, including your name, date of birth, and address.","<strong>Provide</strong> your identification details, like your driver's license or ID number. ","<strong>Attach</strong> a recent passport photo that meets official guidelines.","<strong>Sign</strong> the form in the designated area, as your signature is required.  ","If required, <strong>sign</strong> the form electronically.","<strong>Sign</strong> the form in the designated area, as your signature is required.  "]},whoIsSection:{title:"Who needs to fill out Form DS-11?",items:["Anyone applying for a U.S. Passport must complete Form DS-11. This includes first-time applicants.","People who are renewing or replacing a passport do not need to fill out this form."]},faqSection:{title:"FAQ",items:[{title:"What is the difference between an electronic and a digital signature?",text:"An electronic signature is a way to show agreement on a document using a simple mark or click, while a digital signature uses encryption for added security. It’s important to remember that TheBestPDF only supports electronic signatures. This means you can create a basic signature for your forms, but you won’t be able to use digital signatures with our platform."},{title:"Can I save my progress while filling out a form on TheBestPDF?",text:"Yes, we can save our progress while filling out a form on TheBestPDF. Once we edit the form, it gets saved in our account. This means we can always return later to continue editing whenever we need to. It’s a helpful way to manage our forms without feeling rushed."},{title:"Can I submit my completed forms with TheBestPDF?",text:"No, we cannot submit completed forms through TheBestPDF. Our platform allows you to fill out official forms and download them for future use, but it does not support online submission or sharing. Once you finish filling out a form, you can save it to your device for printing or mailing as needed."},{title:"Can I access TheBestPDF on mobile devices or tablets?",text:"Yes, we can access TheBestPDF on mobile devices and tablets. Our platform is designed to work on various screen sizes, allowing busy professionals to fill out official forms anytime and anywhere. Simply open your browser, go to our site, and start using our PDF editing tools to complete your forms efficiently."}]},contentNav:["What is a DS-11 form?","How to fill a DS-11 form?","Who is required to fill out a DS-11 form?","FAQ"],ctaTitles:["Complete form DS-11 for passport","Fill form DS-11 for tax info needs"],meta:{title:"Easily Manage Your Documents with TheBestPDF",description:"Welcome to our cutting-edge SaaS platform for online document editing and conversion. Designed to meet the needs of businesses and entrepreneurs."},icon:Nl,availableFormats:".pdf"},{serviceType:hn.EDITOR,funnel:En.FILL_PDF,pagesCount:6,path:Ze.FORM_DS82,filePath:Hge,fileName:"ds82.pdf",name:"DS-82",nameKey:"landing.form_ds82.name",title:"Fill Out Your DS-82 Passport Renewal Application Online",description:"Latest Printable Template Available Here",caption:`This website is not affiliated with IRS <br/> 
      Form last updated: ${pc().format("MM/YYYY")}.<br/>
      Please verify this is the current version before use`,from:"PDF",to:"PDF",mainBackground:qge,aboutSection:{title:"Get your Form DS-82 now!",items:[{label:"Open the form",description:"Access the pre-loaded form directly in our PDF editor. No need to upload anything!",icon:Fu,color:"#3758F9"},{label:"Fill in your details",description:"Carefully complete all required fields to ensure accuracy and validity.",icon:Lu,color:"#13C296"},{label:"Download as PDF",description:"Save your filled-out form in PDF format, ready for submission or other needs.",icon:ju,color:"#3758F9"}]},whatIsSection:{title:"What is form DS-82?",text:"Form DS-82 is the U.S. Passport Renewal Application for eligible individuals. This form is essential for those who need to renew their passport without visiting a passport acceptance facility. It is typically used by applicants whose passports are undamaged, issued when they were age 16 or older, and issued within the last 15 years. Completing this form allows us to maintain valid travel documentation, which is necessary for international travel and identification purposes."},howToSection:{title:"How to fill out Form DS-82?",background:"#3758F9",icon:Mu,items:["<strong>Read</strong> the instructions carefully on Form DS-82.  ","<strong>Fill</strong> in your personal information, including name, date of birth, and passport number.","<strong>Select</strong> the reason for renewal.","<strong>Attach</strong> a recent passport photo that meets official guidelines.","<strong>Sign</strong> the form if required; check the instructions.  ","<strong>Prepare</strong> your payment and any additional documents needed.  ","<strong>Mail</strong> the completed form to the address specified in the instructions."]},whoIsSection:{title:"Who needs to fill out Form DS-82?",items:["We are responsible for completing Form DS-82 if we are renewing our U.S. passport. This applies to eligible individuals who meet the criteria.","People who are not renewing a passport or do not meet the eligibility requirements do not need to fill out this form."]},faqSection:{title:"FAQ",items:[{title:"What is the difference between an electronic and a digital signature?",text:"An electronic signature is a digital representation of a person's intent to agree to a document, like typing your name. In contrast, a digital signature uses encryption for added security and verifies the signer’s identity. At TheBestPDF, we support only electronic signatures, which you can create for forms that accept them. Remember, electronic signatures do not provide the same level of security as digital signatures."},{title:"Can I save my progress while filling out a form on TheBestPDF?",text:"Yes, we can save our progress while filling out a form on TheBestPDF. After we edit the form, it gets saved in our account. This way, we can always return to it later and continue editing whenever we need to."},{title:"Can I submit my completed forms with TheBestPDF?",text:"No, we cannot submit completed forms using TheBestPDF. Our platform allows you to fill out forms and download them for your records, but it does not support submitting or sharing them online. Once you've filled out your form, you can save it to your device for later use or to send by mail."},{title:"Can I access TheBestPDF on mobile devices or tablets?",text:"Yes, we can access TheBestPDF on mobile devices and tablets. Our platform is designed to work on various devices, making it convenient for busy professionals. Just open your browser, go to TheBestPDF, and you can fill out forms right from your phone or tablet. This way, we can manage our official documents anytime and anywhere!"}]},contentNav:["What is a DS-82 form?","How to fill a DS-82 form?","Who is required to fill out a DS-82 form?","FAQ"],ctaTitles:["Complete form DS-82 today!","Fill form W-9 for tax info needs"],meta:{title:"Easily Manage Your Documents with TheBestPDF",description:"Welcome to our cutting-edge SaaS platform for online document editing and conversion. Designed to meet the needs of businesses and entrepreneurs."},icon:Nl,availableFormats:".pdf"},{serviceType:hn.EDITOR,funnel:En.FILL_PDF,pagesCount:4,path:Ze.FORM_CMS_1500,filePath:zge,fileName:"cms-1500.pdf",name:"CMS-1500",nameKey:"landing.form_cms_1500.name",title:"Fill Out Form CMS-1500: Health Insurance Claim Form",description:"Latest Printable Template Available",caption:`This website is not affiliated with CMS <br/> 
      Form last updated: ${pc().format("MM/YYYY")}.<br/>
      Please verify this is the current version before use`,from:"PDF",to:"PDF",mainBackground:Bge,aboutSection:{title:"Get your Form CMS-1500 now!",items:[{label:"Open the form",description:"Access the pre-loaded form directly in our PDF editor. No need to upload anything!",icon:Fu,color:"#3758F9"},{label:"Fill in your details",description:"Carefully complete all required fields to ensure accuracy and compliance.",icon:Lu,color:"#13C296"},{label:"Download as PDF",description:"Save your filled-out form in PDF format, ready for submission or other needs.",icon:ju,color:"#3758F9"}]},whatIsSection:{title:"What is Form CMS-1500?",text:"Form CMS-1500 is the standard claim form used by healthcare providers to bill Medicare and Medicaid, as well as many private insurers. It is primarily used by non-institutional providers, such as physicians, therapists, and other medical professionals. Completing this form correctly ensures that healthcare services are billed and reimbursed accurately."},howToSection:{title:"How to fill out Form CMS-1500?",background:"#3758F9",icon:Mu,items:["<strong>Open</strong> the CMS-1500 form in the PDF editor.","<strong>Enter</strong> patient information, including name, date of birth, and insurance details.","<strong>Provide</strong> healthcare provider details, including name, address, and NPI (National Provider Identifier).","<strong>Fill</strong> in diagnosis codes (ICD-10) and procedure codes (CPT/HCPCS) relevant to the medical services provided.","<strong>Review</strong> the form for accuracy and compliance with insurer requirements.","If required, <strong>sign</strong> the form electronically.","<strong>Download</strong> the completed form for submission to the insurer."]},whoIsSection:{title:"Who needs to fill out Form CMS-1500?",items:["Healthcare providers, including physicians, therapists, and outpatient medical professionals, who need to submit insurance claims for reimbursement.","Medical billing specialists handling claims for Medicare, Medicaid, or private insurance companies."]},faqSection:{title:"FAQ",items:[{title:"Can I submit Form CMS-1500 electronically?",text:"Yes, Form CMS-1500 can be submitted electronically via EDI (Electronic Data Interchange) using the 837P format. However, some insurers may still accept paper submissions."},{title:"Can I save my progress while filling out a form on TheBestPDF?",text:"Yes, you can save your progress while filling out a form on TheBestPDF. After editing, the file is saved in your account, allowing you to return anytime and continue working on it."},{title:"Can I submit my completed forms with TheBestPDF?",text:"No, TheBestPDF does not support submitting forms directly. You can fill out and download the form, then submit it via mail or electronic claim submission portals."},{title:"Can I access TheBestPDF on mobile devices or tablets?",text:"Yes, TheBestPDF is accessible on mobile devices and tablets. You can fill out and manage your forms on the go using any web browser."}]},contentNav:["What is a CMS-1500 form?","How to fill a CMS-1500 form?","Who needs to complete a CMS-1500 form?","FAQ"],ctaTitles:["Complete Form CMS-1500 for medical billing","Fill Form CMS-1500 for insurance claims"],meta:{title:"Easily Manage Your Documents with TheBestPDF",description:"Welcome to our cutting-edge SaaS platform for online document editing and conversion. Designed to meet the needs of businesses and entrepreneurs."},icon:Nl,availableFormats:".pdf"},{serviceType:hn.EDITOR,funnel:En.FILL_PDF,pagesCount:4,path:Ze.FORM_W4,filePath:Qge,fileName:"w-4.pdf",name:"W-4",nameKey:"landing.form_w4.name",title:"Fill Out Form W-4: Employee's Withholding Certificate",description:"Latest Printable Template Available",caption:`This website is not affiliated with IRS <br/> 
      Form last updated: ${pc().format("MM/YYYY")}.<br/>
      Please verify this is the current version before use`,from:"PDF",to:"PDF",mainBackground:Xge,aboutSection:{title:"Get your Form W-4 now!",items:[{label:"Open the form",description:"Access the pre-loaded form directly in our PDF editor. No need to upload anything!",icon:Fu,color:"#3758F9"},{label:"Fill in your details",description:"Complete all required fields carefully to ensure accurate tax withholding.",icon:Lu,color:"#13C296"},{label:"Download as PDF",description:"Save your filled-out form in PDF format, ready for submission to your employer.",icon:ju,color:"#3758F9"}]},whatIsSection:{title:"What is Form W-4?",text:"Form W-4, Employee's Withholding Certificate, is used by employees to provide their employer with information about how much federal income tax to withhold from their paycheck. Accurately completing the form ensures the right amount is deducted, avoiding underpayment or overpayment."},howToSection:{title:"How to fill out Form W-4?",background:"#3758F9",icon:Mu,items:["<strong>Open</strong> the W-4 form in the PDF editor.","<strong>Enter</strong> your personal information, including name, address, and Social Security Number.","<strong>Indicate</strong> your filing status (Single, Married, Head of Household).","<strong>Complete</strong> the multiple jobs worksheet if applicable.","<strong>Claim</strong> any dependents if eligible.","<strong>Adjust</strong> additional withholding if necessary.","<strong>Review</strong> your form for accuracy before signing."]},whoIsSection:{title:"Who needs to fill out Form W-4?",items:["All employees must complete Form W-4 when starting a new job to determine federal tax withholding.","Employees who experience financial or dependent changes should update their W-4."]},faqSection:{title:"FAQ",items:[{title:"Can I submit Form W-4 electronically?",text:"Yes, many employers allow electronic submission of Form W-4 through payroll systems. Check with your employer for options."},{title:"Can I save my progress while filling out a form on TheBestPDF?",text:"Yes, your progress is saved in your account, allowing you to return anytime and continue working."},{title:"Can I submit my completed forms with TheBestPDF?",text:"No, TheBestPDF does not support submitting forms directly. You can fill out and download the form, then submit it to your employer."},{title:"Can I access TheBestPDF on mobile devices or tablets?",text:"Yes, TheBestPDF is accessible on mobile devices and tablets, enabling easy form completion on the go."}]},contentNav:["What is a W-4 form?","How to fill a W-4 form?","Who needs to complete a W-4 form?","FAQ"],ctaTitles:["Complete Form W-4 for tax withholding","Fill Form W-4 for accurate payroll deductions"],meta:{title:"Easily Manage Your Documents with TheBestPDF",description:"Welcome to our cutting-edge SaaS platform for online document editing and conversion. Designed to meet the needs of businesses and entrepreneurs."},icon:Nl,availableFormats:".pdf"},{serviceType:hn.EDITOR,funnel:En.FILL_PDF,pagesCount:10,path:Ze.FORM_I864,filePath:Yge,fileName:"i-864.pdf",name:"I-864",nameKey:"landing.form_i864.name",title:"Fill Out Form I-864: Affidavit of Support",description:"Latest Printable Template Available",caption:`This website is not affiliated with USCIS <br/> 
      Form last updated: ${pc().format("MM/YYYY")}.<br/>
      Please verify this is the current version before use`,from:"PDF",to:"PDF",mainBackground:Gge,aboutSection:{title:"Get your Form I-864 now!",items:[{label:"Open the form",description:"Access the pre-loaded form directly in our PDF editor. No need to upload anything!",icon:Fu,color:"#3758F9"},{label:"Fill in your details",description:"Carefully complete all required fields to ensure accuracy and compliance.",icon:Lu,color:"#13C296"},{label:"Download as PDF",description:"Save your filled-out form in PDF format, ready for submission or other needs.",icon:ju,color:"#3758F9"}]},whatIsSection:{title:"What is Form I-864?",text:"Form I-864, Affidavit of Support, is a document required by U.S. Citizenship and Immigration Services (USCIS) to demonstrate that an immigrant has adequate financial support and is unlikely to become a public charge. It is typically completed by a sponsor who agrees to support the intending immigrant financially. This form is crucial for family-based immigrants and some employment-based immigrants."},howToSection:{title:"How to fill out Form I-864?",background:"#3758F9",icon:Mu,items:["<strong>Open</strong> the I-864 form in the PDF editor.","<strong>Enter</strong> the sponsor’s personal details, including name, address, and contact information.","<strong>Provide</strong> details about the sponsored immigrant and relationship to the sponsor.","<strong>Fill in</strong> income details and attach required financial documentation.","<strong>Review</strong> the form to ensure all information is accurate and complete.","If required, <strong>sign</strong> the form electronically.","<strong>Download</strong> the completed form for submission."]},whoIsSection:{title:"Who needs to fill out Form I-864?",items:["Sponsors petitioning for family-based green card applicants must complete Form I-864.","Certain employment-based immigrants whose employer is a relative or has a significant ownership interest may also need to submit this form."]},faqSection:{title:"FAQ",items:[{title:"What documents should I include with Form I-864?",text:"Sponsors must submit proof of income, such as tax returns, W-2 forms, and recent pay stubs. Additional documentation may be required based on the sponsor's financial situation."},{title:"Can I use assets to meet the income requirement?",text:"Yes, if your income alone does not meet the requirements, you may include assets like savings, stocks, or property to compensate for the shortfall."},{title:"What happens if my income does not meet the minimum requirement?",text:"If your income is insufficient, you may need a joint sponsor who meets the financial requirements to submit an additional Form I-864."},{title:"Can I submit Form I-864 electronically?",text:"No, USCIS requires Form I-864 to be printed, signed, and submitted as a physical document. However, you can fill it out and download it for printing using TheBestPDF."}]},contentNav:["What is Form I-864?","How to fill out Form I-864?","Who needs to fill out Form I-864?","FAQ"],ctaTitles:["Complete Form I-864 for sponsorship","Fill Form I-864 for immigration support"],meta:{title:"Easily Manage Your Documents with TheBestPDF",description:"Welcome to our cutting-edge SaaS platform for online document editing and conversion. Designed to meet the needs of businesses and entrepreneurs."},icon:Nl,availableFormats:".pdf"},{serviceType:hn.EDITOR,funnel:En.FILL_PDF,pagesCount:4,path:Ze.FORM_I9,filePath:Kge,fileName:"i-9.pdf",name:"I-9",nameKey:"landing.form_i9.name",title:"Fill Out Form I-9: Employment Eligibility Verification",description:"Latest Printable Template Available",caption:`This website is not affiliated with USCIS <br/> 
      Form last updated: ${pc().format("MM/YYYY")}.<br/>
      Please verify this is the current version before use`,from:"PDF",to:"PDF",mainBackground:Wge,aboutSection:{title:"Get your Form I-9 now!",items:[{label:"Open the form",description:"Access the pre-loaded form directly in our PDF editor. No need to upload anything!",icon:Fu,color:"#3758F9"},{label:"Fill in your details",description:"Carefully complete all required fields to ensure accuracy and validity.",icon:Lu,color:"#13C296"},{label:"Download as PDF",description:"Save your filled-out form in PDF format, ready for submission or other needs.",icon:ju,color:"#3758F9"}]},whatIsSection:{title:"What is Form I-9?",text:"Form I-9, Employment Eligibility Verification, is used by employers to verify the identity and employment authorization of individuals hired for work in the United States. All U.S. employers must ensure that Form I-9 is properly completed for each individual they hire, including citizens and noncitizens. Employees must provide acceptable documents proving their identity and eligibility to work in the U.S."},howToSection:{title:"How to fill out Form I-9?",background:"#3758F9",icon:Mu,items:["<strong>Open</strong> the I-9 form in the PDF editor.","<strong>Fill</strong> in your personal information, including your name, address, and date of birth.","<strong>Provide</strong> your Social Security Number (if applicable).","<strong>Select</strong> your employment authorization status and provide necessary details.","<strong>Present</strong> acceptable documents to verify your identity and work authorization.","<strong>Review</strong> all information for accuracy.","<strong>Download</strong> the completed form for submission to your employer."]},whoIsSection:{title:"Who needs to fill out Form I-9?",items:["All employees hired for work in the United States must complete Form I-9, regardless of citizenship status.","Employers must retain a completed Form I-9 for each employee and make it available for inspection upon request by authorized government officials."]},faqSection:{title:"FAQ",items:[{title:"What documents do I need to provide for Form I-9?",text:"Employees must provide either one document from List A (e.g., U.S. Passport) or one document each from List B (e.g., Driver’s License) and List C (e.g., Social Security Card). Employers must verify these documents."},{title:"Can I fill out Form I-9 online?",text:"Yes, Form I-9 can be completed digitally using our PDF editor. However, the form must be printed and signed physically unless an employer uses an electronic I-9 system compliant with USCIS regulations."},{title:"Do employers need to submit Form I-9 to the government?",text:"No, employers do not submit Form I-9 to the government but must retain it for three years after the hire date or one year after employment ends, whichever is later."},{title:"Can I access TheBestPDF on mobile devices or tablets?",text:"Yes, we can access TheBestPDF on mobile devices and tablets. Our platform is designed to work on various screens, allowing busy professionals to fill out official forms on the go. Just open your device's web browser, and you can start editing PDFs wherever you are."}]},contentNav:["What is a I-9 form?","How to fill a I-9 form?","Who is required to fill out a I-9 form?","FAQ"],ctaTitles:["Complete Form I-9 for employment verification","Fill Form I-9 for work eligibility needs"],meta:{title:"Easily Manage Your Documents with TheBestPDF",description:"Welcome to our cutting-edge SaaS platform for online document editing and conversion. Designed to meet the needs of businesses and entrepreneurs."},icon:Nl,availableFormats:".pdf"}],gN=e=>({key:xr.MAIN_PAGE,serviceType:hn.CONVERTOR,funnel:En.PDF_TO_PNG,path:Ze.PDF_TO_PNG,name:e("main_page.name"),nameKey:"main_page.name",title:e("main_page.h1.title"),description:e("main_page.h1.subtitle"),aboutSection:{title:e("main_page.features.h2"),items:[e("main_page.features.1"),e("main_page.features.2"),e("main_page.features.3")]},aboutSectionNoDelayFreeFlow:{title:e("main_pag